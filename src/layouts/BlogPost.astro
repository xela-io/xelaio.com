---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, heroImage, id } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title={`${title} - xelaio.com`}
			description={description}
			image={heroImage}
			article={{
				headline: title,
				publishedTime: pubDate.toISOString(),
				...(updatedDate && { modifiedTime: updatedDate.toISOString() }),
			}}
		/>
	</head>

	<body>
		<Header />
		<main>
			<article transition:animate="fade">
				<header class="article-header">
					<h1 style="color: var(--orange);">{title}</h1>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(aktualisiert: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(16px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.article-header {
		margin-bottom: 2rem;
	}
	.meta {
		animation: fadeIn 0.4s ease 0.1s both;
	}
	.prose {
		animation: fadeIn 0.4s ease 0.2s both;
	}
	.article-header h1 {
		margin: 0 0 0.5rem 0;
		font-size: 2em;
		line-height: 1.2;
		color: var(--orange);
	}
	.meta {
		color: var(--text-muted);
		font-size: 0.9rem;
	}
	.updated {
		font-style: italic;
	}
	.prose {
		line-height: 1.8;
	}
	.prose :global(p) {
		margin: 0 0 0.75em 0;
	}
	.prose :global(h2) {
		margin-top: 2.2em;
		margin-bottom: 0.6em;
		padding-left: 0.6em;
		border-left: 3px solid var(--accent);
	}
	.prose :global(h3) {
		margin-top: 1.6em;
		margin-bottom: 0.4em;
		padding-left: 0.6em;
		border-left: 2px solid var(--border);
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(a:hover) {
		color: var(--accent-hover);
	}
	.prose :global(img) {
		margin: 1.5em 0;
	}
	.prose :global(pre) {
		margin: 1.5em 0;
	}
</style>
