---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { id?: string };

const { title, description, pubDate, updatedDate, id } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={`${title} - over-cloud.de`} description={description} />
	</head>

	<body>
		<Header />
		<main>
			<article transition:animate="fade">
				<header class="article-header">
					<h1 transition:name={id ? `title-${id}` : undefined}>{title}</h1>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									(aktualisiert: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-header {
		margin-bottom: 2rem;
	}
	.article-header h1 {
		margin: 0 0 0.5rem 0;
		font-size: 2em;
		line-height: 1.2;
	}
	.meta {
		color: var(--text-muted);
		font-size: 0.9rem;
	}
	.updated {
		font-style: italic;
	}
	.prose {
		line-height: 1.8;
	}
	.prose :global(h2) {
		margin-top: 2em;
	}
	.prose :global(h3) {
		margin-top: 1.5em;
	}
	.prose :global(a) {
		color: var(--accent);
	}
	.prose :global(a:hover) {
		color: var(--accent-hover);
	}
	.prose :global(img) {
		margin: 1.5em 0;
	}
	.prose :global(pre) {
		margin: 1.5em 0;
	}
</style>
